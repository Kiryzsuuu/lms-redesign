# ===== Production env untuk Biznet NEO VPS =====
# Copy file ini ke: server/.env  (di server, JANGAN commit yang berisi secret asli)
#   cp .env.biznet.example server/.env  && nano server/.env

NODE_ENV=production
PORT=4000

# MongoDB Atlas connection string (Database > Connect > Drivers)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/lms?retryWrites=true&w=majority

# Minimal 16 karakter. Generate: openssl rand -hex 32
JWT_SECRET=ganti-dengan-string-acak-panjang

# Domain publik (dipakai untuk CORS + link email/sertifikat)
CLIENT_ORIGIN=https://edulyfe.id

# ---- Midtrans (opsional, bisa diisi via panel admin) ----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ---- SMTP (opsional, bisa diisi via panel admin) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# JANGAN diaktifkan di production
DEBUG_OTP=false
