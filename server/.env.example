# ══════════════════════════════════════════════════════
# LMS InspiraLearn — Server Environment Variables
# Copy this file to server/.env and fill in your values.
# ══════════════════════════════════════════════════════

# Server port
PORT=4000

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT secret (min 32 chars, random string)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Allowed frontend origin(s) for CORS. Comma-separated for multiple.
CLIENT_ORIGIN=http://localhost:5173

# ── MIDTRANS (optional — can be configured via Admin → Pengaturan Situs → Midtrans) ──
# If both DB setting AND env var are set, DB setting takes priority.
# These env vars serve as fallback for deployments before admin configures via UI.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_FEE_PERCENT=0
# Per-method fee rules JSON. Example: {"qris":{"percent":0.7},"bank_transfer":{"flat":4000}}
MIDTRANS_FEE_RULES_JSON=

# ── SMTP (optional — can be configured via Admin → Pengaturan Situs → Email/SMTP) ──
# If DB setting is configured, it takes priority over these env vars.
# For Gmail: use an App Password. SMTP_HOST=smtp.gmail.com, SMTP_PORT=465
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── OTP DEBUGGING — LOCAL DEV ONLY ──
# When true, OTP code is returned in API response (no email needed).
# MUST remain false/unset in production.
DEBUG_OTP=false
